  "keyFeatures": [
    "Multi-block television system with dynamic sizing up to 8x8 blocks",
    "Cassette tape playback system with animated video content",
    "Live camera viewfinder blocks for broadcasting",
    "Hollow cassettes for linking viewfinders to televisions",
    "Special mob interactions including Enderman freeze behavior",
    "Multi-loader support for both Fabric and NeoForge"
  ],
  "publicApiSurface": [
    "VistaMod - Main mod initialization class",
    "TVBlock - Television block implementation",
    "TVBlockEntity - Television block entity",
    "ViewFinderBlock - Viewfinder block implementation",
    "ViewFinderBlockEntity - Viewfinder block entity",
    "CassetteItem - Cassette item with tape data",
    "HollowCassetteItem - Hollow cassette for broadcasting",
    "CassetteTape - Cassette tape data record",
    "BroadcastManager - World saved data for viewfinder connections",
    "BroadcastLocationType - Registry for broadcast location types",
    "IBroadcastSource - Interface for broadcast sources",
    "ITvCassette - Interface for TV cassette items",
    "TVType - Enum for TV connection types",
    "PowerState - Enum for TV power states",
    "CASSETTE_TAPE_REGISTRY_KEY - Data pack registry for cassette tapes",
    "BROADCAST_LOCATION_REGISTRY - Registry for broadcast location types"
  ]
